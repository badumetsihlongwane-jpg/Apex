@charset "utf-8";

pre[class*="language-"].line-numbers { counter-reset: linenumber 0; padding-left: 3.8em; position: relative; }

pre[class*="language-"].line-numbers > code { white-space: inherit; position: relative; }

.line-numbers .line-numbers-rows { pointer-events: none; letter-spacing: -1px; user-select: none; border-right: 1px solid rgb(153, 153, 153); width: 3em; font-size: 100%; position: absolute; top: 0px; left: -3.8em; }

.line-numbers-rows > span { counter-increment: linenumber 1; display: block; }

.line-numbers-rows > span::before { content: counter(linenumber); color: rgb(153, 153, 153); text-align: right; padding-right: 0.8em; display: block; }

pre[data-line] { padding: 1em 0px 1em 3em; position: relative; }

.line-highlight { pointer-events: none; line-height: inherit; white-space: pre; background: linear-gradient(90deg, rgba(153, 122, 102, 0.1) 70%, rgba(153, 122, 102, 0)); margin-top: 1em; position: absolute; left: 0px; right: 0px; }

@media print {
  .line-highlight { print-color-adjust: exact; }
}

.line-highlight::before, .line-highlight[data-end]::after { content: attr(data-start); color: rgb(245, 242, 240); text-align: center; vertical-align: 0.3em; min-width: 1em; text-shadow: none; background-color: rgba(153, 122, 102, 0.4); border-radius: 999px; padding: 0px 0.5em; font: 700 65% / 1.5 sans-serif; position: absolute; top: 0.4em; left: 0.6em; box-shadow: rgb(255, 255, 255) 0px 1px; }

.line-highlight[data-end]::after { content: attr(data-end); top: auto; bottom: 0.4em; }

.line-numbers .line-highlight::before, .line-numbers .line-highlight::after { content: none; }

pre[id].linkable-line-numbers span.line-numbers-rows { pointer-events: all; }

pre[id].linkable-line-numbers span.line-numbers-rows > span::before { cursor: pointer; }

pre[id].linkable-line-numbers span.line-numbers-rows > span:hover::before { background-color: rgba(128, 128, 128, 0.2); }
